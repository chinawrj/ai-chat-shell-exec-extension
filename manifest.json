{
  "manifest_version": 3,
  "name": "AI Chat Shell Exec",
  "description": "Runs explicit ai-helper shell blocks from AI chat pages via a local WebSocket shell server and posts shell-output back to the conversation.",
  "version": "0.8.1",
  "key": "",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://127.0.0.1:17371/*",
    "ws://127.0.0.1:17371/*"
  ],
  "background": {
    "service_worker": "extension/src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/*"
      ],
      "js": [
        "extension/src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AI Chat Shell Exec",
    "default_popup": "extension/popup.html"
  }
}
